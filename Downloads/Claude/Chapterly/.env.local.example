# ──────────────────────────────────────────────────────
# Chapterly Environment Configuration
# Copy this file to .env.local and fill in your values
#
# Project root: C:\Users\maxmw\Downloads\Claude\Chapterly
# ──────────────────────────────────────────────────────

# Supabase (get from supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Google Books API (optional — enriches metadata; works without it)
GOOGLE_BOOKS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Chapterly
